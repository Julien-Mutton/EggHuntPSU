# ─── Database ───────────────────────────────────────────
DB_NAME=egghunt
DB_USER=egghunt
DB_PASSWORD=egghunt123
DB_HOST=localhost
DB_PORT=5432

# ─── Django ─────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.ngrok-free.app,.ngrok.io

# ─── URLs (used for QR code links, CORS, and CSRF) ─────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ─── Google OAuth (optional) ────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Microsoft OAuth (optional) ──────────────────────────
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ─── Frontend (.env in /frontend) ───────────────────────
# VITE_API_URL=http://localhost:8000/api
# VITE_GOOGLE_CLIENT_ID=    # Same as GOOGLE_OAUTH_CLIENT_ID for OAuth popup
# VITE_MICROSOFT_CLIENT_ID= # Same as MICROSOFT_OAUTH_CLIENT_ID for OAuth popup

# ─── Ngrok Deployment ──────────────────────────────────
# When deploying through ngrok, update these values:
# FRONTEND_URL=https://your-frontend-subdomain.ngrok-free.app
# BACKEND_URL=https://your-backend-subdomain.ngrok-free.app
# VITE_API_URL=https://your-backend-subdomain.ngrok-free.app/api
